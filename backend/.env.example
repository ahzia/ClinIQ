APP_NAME="Smart Health Mapping Backend"
APP_ENV="dev"
APP_VERSION="0.1.0"
API_PREFIX="/api/v1"
CASE_LINK_WINDOW_HOURS=6
IDENTITY_CONFLICT_HIGH_THRESHOLD=2
PROCESSED_DB_PATH="data/processed/harmonized.sqlite"
AI_ENABLED=true
AI_PROVIDER="openai"
AI_MODEL="gpt-4o-mini"
AI_API_KEY=""
AI_API_BASE_URL="https://api.openai.com/v1"
AI_TIMEOUT_SECONDS=25
DB_MOVE_INCLUDE_WARNINGS=true
DB_MOVE_WARNING_SCORE_THRESHOLD=0.80
